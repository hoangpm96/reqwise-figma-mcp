{
  "compilerOptions": {
    "target": "ES2017",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "noEmit": true,
    "lib": ["ES2017"],
    "typeRoots": ["node_modules/@figma", "node_modules/@types"]
  },
  "include": ["src/plugin/**/*", "src/shared/**/*", "tests/plugin/**/*"]
}
